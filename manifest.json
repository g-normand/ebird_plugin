{
  "manifest_version": 3,
  "name": "Flagged pictures",
  "version": "0.1.1",
  "description": "eBird flagged pictures",
  "icons": {
    "48": "icons/icon.png"
  },
  "action": {
    "default_icon": "icons/icon.png"
  },
  "content_scripts": [{
    "matches": [
	  "*://ebird.org/*",
	  "*://*.ebird.org/*"
     ],
    "js": ["content-script.js"]
  }],
  "permissions": ["storage", "tabs"]
}
