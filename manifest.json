{
  "manifest_version": 2,
  "name": "Flagged pictures",
  "version": "0.1",
  "description": "eBird flagged pictures",
  "icons": {
    "48": "icons/icon.png"
  },
  "browser_action": {
    "default_icon": "icons/icon.png"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content-script.js"]
  }],
  "permissions": ["storage", "tabs"]
}
